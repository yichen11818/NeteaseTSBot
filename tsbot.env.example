# Unified configuration for tsbot (backend / web / voice-service)

# 后端服务配置
export TSBOT_HOST="127.0.0.1"
export TSBOT_PORT="8009"

# Backend -> voice-service gRPC address
export TSBOT_VOICE_GRPC_ADDR="127.0.0.1:50051"
export TSBOT_COOKIE_KEY="your_cookie_key"

# TeamSpeak 服务器配置（used by voice-service；历史变量名 `TSBOT_TS3_*` 也用于 TS6 主客户端连接）
export TSBOT_TS3_HOST="your_teamspeak_server_ip"
export TSBOT_TS3_PORT="9987"
export TSBOT_TS3_NICKNAME="tsbot"
export TSBOT_TS3_CHANNEL_ID="2"
export TSBOT_TS3_IDENTITY_FILE="./logs/identity.json"
# export TSBOT_TS3_IDENTITY=""
# export TSBOT_TS3_SERVER_PASSWORD=""
# export TSBOT_TS3_CHANNEL_PASSWORD=""
# export TSBOT_TS3_CHANNEL_PATH=""
# export TSBOT_TS3_AVATAR_DIR="./assets/avatars"

# Optional legacy ServerQuery fallback for older servers only.
# This is NOT the TS6 HTTP(S) Query interface.
# export TSBOT_TS3_SERVERQUERY_USER=""
# export TSBOT_TS3_SERVERQUERY_PASSWORD=""
# export TSBOT_TS3_SERVERQUERY_HOST=""
# export TSBOT_TS3_SERVERQUERY_PORT="10011"
# export TSBOT_TS3_SERVERQUERY_SID=""
# export TSBOT_TS3_SERVERQUERY_USE_PORT="9987"

# Web (Vite)

export VITE_DEV_HOST="127.0.0.1"
export VITE_DEV_PORT="8080"

# 音乐源配置
# 网易云功能依赖你自己部署的 NeteaseCloudMusicApi。
export TSBOT_NETEASE_API_BASE="http://127.0.0.1:3000/"
# QQ 音乐与网易云管理员 cookie 通过 Web 控制台或 admin API 写入数据库，
# 并使用 TSBOT_COOKIE_KEY 加密存储；无需在这里明文填写。

# 数据库配置
export DATABASE_URL="sqlite:///./tsbot.db"

# 开发模式 (true/false)
export  DEBUG=false

# 日志配置
export TSBOT_LOG_LEVEL="INFO"
export TSBOT_LOG_FILE="logs/backend.log"
export VITE_LOG_LEVEL="INFO"
